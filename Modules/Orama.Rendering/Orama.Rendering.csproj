<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AssimpNetter" Version="6.0.5" />
    <PackageReference Include="Silk.NET.Windowing" Version="2.23.0" />
    <PackageReference Include="SlangShaderSharp" Version="2026.13.1" />
    <PackageReference Include="StbImageSharp" Version="2.30.15" />
    <PackageReference Include="Veldrith" Version="1.2.18" />
    <PackageReference Include="Veldrith.SPIRV" Version="1.2.18" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Orama.Common\Orama.Common.csproj" />
    <ProjectReference Include="..\..\Orama.Math\Orama.Math.csproj" />
    <ProjectReference Include="..\Orama.Input\Orama.Input.csproj" />
    <ProjectReference Include="..\Orama.Physics\Orama.Physics.csproj" />
    <ProjectReference Include="..\Orama.Scenes\Orama.Scenes.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\Orama\Attributes.slang">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Orama\Debug.slang">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Orama\DummyLit.slang">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Orama\Unlit.slang">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Orama\Preprocessor.slang">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Orama\Core.slang">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Texture.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
